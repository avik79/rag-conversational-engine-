# LLM Configuration
# NOTE: The openai-agents SDK requires BOTH APIs due to its architecture.
# Even though we use Claude models, the SDK routes through OpenAI's API.
# Embeddings now use sentence-transformers (local, no API key needed).

ANTHROPIC_API_KEY=sk-ant-...       # Claude models (primary)
OPENAI_API_KEY=sk-...              # Required by openai-agents SDK (for routing, not execution)

# Data APIs
TAVILY_API_KEY=tvly-...            # Tavily weather & news API

# Database Configuration
DATABASE_URL=sqlite:///./data/employees.db
SESSION_DATABASE_URL=sqlite+aiosqlite:///./data/agent_sessions.db

# Chroma Vector Store
CHROMA_HOST=embedded              # "embedded" for in-process, or hostname for HTTP
CHROMA_PORT=8000
CHROMA_PERSIST_DIR=./data/chroma

# Application Tuning
SENTINEL_CONFIDENCE_THRESHOLD=0.75    # Groundedness check threshold
WEATHER_FRESHNESS_HOURS=6              # Max age of weather data (hours)
KIRA_CONFIDENCE_THRESHOLD=0.80         # Location resolution confidence
IRIS_OVERWRITE_THRESHOLD=0.80          # Collection overwrite threshold
TOP_K_RETRIEVAL=4                      # Chroma query results limit

# Development
DEBUG_AGENTS=false
LOG_LEVEL=INFO
